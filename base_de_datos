-- ============================================================
-- Vista útil: resultados de una elección
-- Evita repetir el COUNT en cada consulta del backend.
-- ============================================================

CREATE OR REPLACE VIEW vista_resultados AS
SELECT
    e.id                          AS eleccion_id,
    e.nombre                      AS eleccion_nombre,
    u.id                          AS candidato_id,
    u.nombre                      AS candidato_nombre,
    u.foto                        AS candidato_foto,
    ce.categoria,
    COUNT(v.id)                   AS total_votos
FROM candidatos_elecciones ce
JOIN usuarios   u ON u.id  = ce.usuario_id
JOIN elecciones e ON e.id  = ce.eleccion_id
LEFT JOIN votos v ON v.candidato_eleccion_id = ce.id
GROUP BY ce.id, e.id, u.id, ce.categoria;
