-- ============================================================
--  SISTEMA DE VOTACIONES ESTUDIANTIL — Base de datos mejorada
--  Versión 2.0  |  Revisada y documentada
-- ============================================================

CREATE DATABASE IF NOT EXISTS sistema_votaciones
  CHARACTER SET utf8mb4
  COLLATE utf8mb4_unicode_ci;

USE sistema_votaciones;

-- ============================================================
-- [CAMBIO] Se unificaron candidatos, votantes y admins en una
--          sola tabla `usuarios` con campo `rol`.
--          Evita duplicar lógica de autenticación en 3 tablas.
-- ============================================================

CREATE TABLE usuarios (
    id             INT          AUTO_INCREMENT PRIMARY KEY,
    nombre         VARCHAR(150) NOT NULL,
    email          VARCHAR(150) NOT NULL UNIQUE,
    password_hash  VARCHAR(255) NOT NULL,
    rol            ENUM('superadmin','admin','candidato','votante') NOT NULL DEFAULT 'votante',

    -- Datos de perfil opcionales (útiles para candidatos y votantes)
    foto           VARCHAR(255)  NULL,          -- ruta o URL de imagen de perfil
    telefono       VARCHAR(20)   NULL,
    grado_grupo    VARCHAR(50)   NULL,          -- ej: "3°B" — útil para votantes/candidatos

    -- Control de acceso y seguridad
    activo             BOOLEAN   DEFAULT TRUE,
    ultimo_login       DATETIME  NULL,
    intentos_fallidos  INT       DEFAULT 0,
    bloqueado_hasta    DATETIME  NULL,

    -- [NUEVO] Token para recuperación de contraseña
    reset_token        VARCHAR(100) NULL,
    reset_token_expira DATETIME     NULL,

    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,

    INDEX idx_email  (email),
    INDEX idx_rol    (rol),
    INDEX idx_activo (activo)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;


-- ============================================================
-- Elecciones
-- [CAMBIO] created_by ahora referencia a `usuarios` (no admins)
-- [NUEVO]  campo `tipo_eleccion` y `visible_resultados`
-- ============================================================

CREATE TABLE elecciones (
    id          INT          AUTO_INCREMENT PRIMARY KEY,
    nombre      VARCHAR(200) NOT NULL,
    descripcion TEXT,
    reglas      TEXT,

    fecha_inicio DATETIME NOT NULL,
    fecha_fin    DATETIME NOT NULL,

    -- [NUEVO] Tipo de elección para soportar distintas modalidades
    tipo_eleccion ENUM('presidencia','mesa_directiva','representante','otro') DEFAULT 'otro',

    estado ENUM('borrador','activa','cerrada','publicada') DEFAULT 'borrador',

    -- Configuración de votación
    permite_votos_multiple BOOLEAN DEFAULT FALSE,
    max_votos_por_usuario  INT     DEFAULT 1,

    -- [NUEVO] Controlar si los resultados son visibles antes de cerrar
    visible_resultados BOOLEAN DEFAULT FALSE,

    created_by INT NULL,  -- quién creó la elección (admin o superadmin)
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,

    CONSTRAINT fk_eleccion_creador FOREIGN KEY (created_by)
        REFERENCES usuarios(id) ON DELETE SET NULL,

    -- [NUEVO] Restricción: fecha_fin debe ser posterior a fecha_inicio
    CONSTRAINT chk_fechas CHECK (fecha_fin > fecha_inicio),

    INDEX idx_estado (estado),
    INDEX idx_fechas (fecha_inicio, fecha_fin)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;


-- ============================================================
-- [NUEVA] Tabla intermedia: candidatos_elecciones
--
-- Relaciona un usuario con rol 'candidato' a una elección.
-- Reemplaza la tabla `candidatos` anterior que mezclaba datos
-- de persona con datos de participación en una elección.
-- Esto sigue la 3FN: los datos del candidato viven en `usuarios`,
-- los datos de su postulación viven aquí.
-- ============================================================

CREATE TABLE candidatos_elecciones (
    id          INT AUTO_INCREMENT PRIMARY KEY,
    usuario_id  INT NOT NULL,    -- FK a usuarios (rol = candidato)
    eleccion_id INT NOT NULL,

    -- Datos específicos de la postulación
    propuesta   TEXT,            -- plan de trabajo / propuesta de campaña
    categoria   VARCHAR(100),    -- ej: "Presidente", "Secretario", "Vocal"
    orden       INT DEFAULT 0,   -- orden de aparición en la boleta

    activo  BOOLEAN   DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,

    -- Un candidato solo puede postularse UNA VEZ por elección
    UNIQUE KEY uq_candidato_eleccion (usuario_id, eleccion_id),

    CONSTRAINT fk_cand_usuario  FOREIGN KEY (usuario_id)
        REFERENCES usuarios(id)  ON DELETE CASCADE,
    CONSTRAINT fk_cand_eleccion FOREIGN KEY (eleccion_id)
        REFERENCES elecciones(id) ON DELETE CASCADE,

    INDEX idx_eleccion (eleccion_id),
    INDEX idx_usuario  (usuario_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;


-- ============================================================
-- Votos
-- [CAMBIO] votante_id reemplaza a hash_votante + ip_votante.
--          Con usuarios registrados, el votante es identificable.
--          Se conserva ip_votante solo para auditoría adicional.
-- [CORRECCIÓN] Se eliminó votos_count de candidatos (campo
--          calculado — nunca debe guardarse en base de datos,
--          se obtiene con COUNT(*) al consultar votos).
-- ============================================================

CREATE TABLE votos (
    id          INT AUTO_INCREMENT PRIMARY KEY,

    -- Quién votó
    votante_id  INT NOT NULL,           -- FK a usuarios (rol = votante)

    -- A quién votó (postulación específica)
    candidato_eleccion_id INT NOT NULL, -- FK a candidatos_elecciones

    -- Referencia directa a la elección (facilita consultas)
    eleccion_id INT NOT NULL,

    -- Datos de auditoría de red
    ip_votante  VARCHAR(45)  NULL,      -- IPv4 o IPv6
    user_agent  VARCHAR(255) NULL,

    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    -- [SEGURIDAD] Un votante solo puede votar UNA VEZ por elección
    UNIQUE KEY uq_voto_por_eleccion (votante_id, eleccion_id),

    CONSTRAINT fk_voto_votante   FOREIGN KEY (votante_id)
        REFERENCES usuarios(id)           ON DELETE RESTRICT,
    CONSTRAINT fk_voto_candidato FOREIGN KEY (candidato_eleccion_id)
        REFERENCES candidatos_elecciones(id) ON DELETE RESTRICT,
    CONSTRAINT fk_voto_eleccion  FOREIGN KEY (eleccion_id)
        REFERENCES elecciones(id)         ON DELETE RESTRICT,

    INDEX idx_votante  (votante_id),
    INDEX idx_eleccion (eleccion_id),
    INDEX idx_candidato_eleccion (candidato_eleccion_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;


-- ============================================================
-- [NUEVA] Tabla: votantes_habilitados
--
-- No todos los usuarios con rol 'votante' deben poder votar
-- en todas las elecciones. Esta tabla controla qué votantes
-- están habilitados para cada proceso electoral específico.
-- ============================================================

CREATE TABLE votantes_habilitados (
    id          INT AUTO_INCREMENT PRIMARY KEY,
    votante_id  INT NOT NULL,
    eleccion_id INT NOT NULL,
    habilitado  BOOLEAN DEFAULT TRUE,
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    UNIQUE KEY uq_habilitado (votante_id, eleccion_id),

    CONSTRAINT fk_hab_votante  FOREIGN KEY (votante_id)
        REFERENCES usuarios(id)   ON DELETE CASCADE,
    CONSTRAINT fk_hab_eleccion FOREIGN KEY (eleccion_id)
        REFERENCES elecciones(id) ON DELETE CASCADE,

    INDEX idx_eleccion (eleccion_id),
    INDEX idx_votante  (votante_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;


-- ============================================================
-- Logs de auditoría
-- [CAMBIO] admin_id → usuario_id (cualquier usuario puede
--          generar un log, no solo admins)
-- [NUEVO]  campo `nivel` para clasificar severidad del evento
-- ============================================================

CREATE TABLE logs_auditoria (
    id               INT AUTO_INCREMENT PRIMARY KEY,
    usuario_id       INT NULL,              -- quién realizó la acción
    rol_usuario      VARCHAR(20) NULL,      -- snapshot del rol en el momento

    accion           VARCHAR(100) NOT NULL, -- ej: 'LOGIN', 'VOTO_EMITIDO', 'ELECCION_CREADA'
    nivel            ENUM('info','warning','error') DEFAULT 'info',

    tabla_afectada   VARCHAR(50) NULL,
    registro_id      INT         NULL,

    datos_anteriores JSON NULL,
    datos_nuevos     JSON NULL,

    ip_address       VARCHAR(45)  NULL,
    user_agent       VARCHAR(255) NULL,

    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_log_usuario FOREIGN KEY (usuario_id)
        REFERENCES usuarios(id) ON DELETE SET NULL,

    INDEX idx_usuario    (usuario_id),
    INDEX idx_accion     (accion),
    INDEX idx_nivel      (nivel),
    INDEX idx_fecha      (created_at),
    INDEX idx_tabla      (tabla_afectada)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;


-- ============================================================
-- [NUEVA] Tabla: sesiones_activas
--
-- Permite invalidar sesiones de forma explícita (logout,
-- bloqueo de cuenta) sin depender solo de cookies del lado
-- del cliente.
-- ============================================================

CREATE TABLE sesiones_activas (
    id          INT          AUTO_INCREMENT PRIMARY KEY,
    usuario_id  INT          NOT NULL,
    token_hash  VARCHAR(64)  NOT NULL UNIQUE,  -- SHA-256 del token de sesión
    ip_address  VARCHAR(45)  NULL,
    user_agent  VARCHAR(255) NULL,
    expira_en   DATETIME     NOT NULL,
    created_at  TIMESTAMP    DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_sesion_usuario FOREIGN KEY (usuario_id)
        REFERENCES usuarios(id) ON DELETE CASCADE,

    INDEX idx_token   (token_hash),
    INDEX idx_usuario (usuario_id),
    INDEX idx_expira  (expira_en)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;


